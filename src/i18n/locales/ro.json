      },
      "1": {
        "q": "Cum pot salva locurile care îmi plac?",
        "a": "Apasă pe iconița inimă la orice loc pentru a-l adăuga la favorite."
      },
      "2": {
        "q": "Pot folosi aplicația offline?",
        "a": "Unele funcții, cum ar fi călătoriile salvate și favoritele, sunt disponibile offline. Hărțile și datele live necesită conexiune la internet."
      },
      "3": {
        "q": "Cum îmi schimb informațiile de profil?",
        "a": "Mergi la Profil > Informații personale și actualizează numele sau alte detalii."
      },
      "4": {
        "q": "Cum activez sau dezactivez notificările?",
        "a": "Mergi la Profil > Setări aplicație și activează sau dezactivează notificările."
      },
      "5": {
        "q": "Mi-am uitat parola. Ce trebuie să fac?",
        "a": "Folosește opțiunea Ai uitat parola de pe ecranul de autentificare sau mergi la Profil > Schimbă parola."
      },
      "6": {
        "q": "Cum activez modul întunecat?",
        "a": "Mergi la Profil > Setări aplicație și activează Modul întunecat."
      },
      "7": {
        "q": "Cum îmi șterg contul?",
        "a": "Mergi la Profil > Șterge contul și urmează instrucțiunile. Această acțiune este permanentă."
      },
      "8": {
        "q": "De ce este necesar accesul la locație?",
        "a": "Accesul la locație ajută la afișarea locurilor, restaurantelor și atracțiilor din apropiere."
      },
      "9": {
        "q": "Cum pot contacta suportul?",
        "a": "Mergi la Profil > Contact support și trimite-ne un email."
      }
    }
  },
