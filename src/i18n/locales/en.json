  "helpFaq": {
    "title": "Help / FAQ",
    "subtitle": "Common questions about using the app.",
    "faqs": {
      "0": {
        "q": "How do I create a trip?",
        "a": "Go to the Trips section and tap the plus (+) button. Add your destination, dates, and activities."
      },
      "1": {
        "q": "How can I save places I like?",
        "a": "Tap the heart icon on any place to add it to your wishlist for later."
      },
      "2": {
        "q": "Can I use the app offline?",
        "a": "Some features such as saved trips and wishlist are available offline. Maps and live data require an internet connection."
      },
      "3": {
        "q": "How do I change my profile information?",
        "a": "Go to Profile > Personal information and update your name or other details."
      },
      "4": {
        "q": "How do I enable or disable notifications?",
        "a": "Go to Profile > App Settings and toggle notifications on or off."
      },
      "5": {
        "q": "I forgot my password. What should I do?",
        "a": "Use the Forgot Password option on the login screen or go to Profile > Change password."
      },
      "6": {
        "q": "How do I switch to dark mode?",
        "a": "Go to Profile > App Settings and enable Dark Mode."
      },
      "7": {
        "q": "How do I delete my account?",
        "a": "Go to Profile > Delete account and follow the instructions. This action is permanent."
      },
      "8": {
        "q": "Why is location access needed?",
        "a": "Location access helps show nearby places, restaurants, and attractions."
      },
      "9": {
        "q": "How can I contact support?",
        "a": "Go to Profile > Contact support and send us an email."
      }
    }
  },
